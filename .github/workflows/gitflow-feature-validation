name: GitFlow - Feature Branch Validation

on:
  pull_request:
    branches:
      - develop

permissions:
  contents: read
  pull-requests: write
  issues: write

jobs:
  validate-feature-branch:
    name: Validate Feature Branch Rules
    runs-on: cp-ubuntu22.04-amd64-1core-1gb
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Check if this is a feature branch
        id: check_branch_type
        run: |
          SOURCE_BRANCH="${{ github.head_ref }}"
          
          # Skip validation if this is not a feature branch
          # (hotfix/* and release/* have their own validation workflows)
          if [[ "$SOURCE_BRANCH" =~ ^feature/.+ ]]; then
            echo "IS_FEATURE_BRANCH=true" >> $GITHUB_OUTPUT
            echo "✅ This is a feature branch: $SOURCE_BRANCH"
          else
            echo "IS_FEATURE_BRANCH=false" >> $GITHUB_OUTPUT
            echo "⏭️  Skipping feature validation - this is not a feature branch ($SOURCE_BRANCH)"
          fi

      - name: Check feature branch is descendant of develop
        if: steps.check_branch_type.outputs.IS_FEATURE_BRANCH == 'true'
        run: |
          SOURCE_BRANCH="${{ github.head_ref }}"
          
          # Find the merge base between the source branch and develop
          MERGE_BASE=$(git merge-base refs/remotes/origin/$SOURCE_BRANCH refs/remotes/origin/develop)
          
          # Check if develop is an ancestor of the feature branch
          if git merge-base --is-ancestor refs/remotes/origin/develop $MERGE_BASE; then
            echo "✅ Feature branch '$SOURCE_BRANCH' was properly branched from develop"
          else
            echo "❌ Feature branch '$SOURCE_BRANCH' was NOT branched from develop"
            echo "Please create your feature branch from the develop branch"
            echo ""
            echo "To fix this:"
            echo "  1. Create a new branch from develop: git checkout develop && git pull && git checkout -b feature/your-feature"
            echo "  2. Cherry-pick your commits or rebase onto develop"
            exit 1
          fi

      - name: Comment PR with validation results
        uses: actions/github-script@v6.4.0
        if: always() && steps.check_branch_type.outputs.IS_FEATURE_BRANCH == 'true'
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          script: |
            const sourceBranch = "${{ github.head_ref }}";
            const conclusion = "${{ job.status }}";
            
            let output = "";
            
            if (conclusion === "success") {
              output = `### GitFlow Feature Branch Validation ✅
            
            **Branch Type:** Feature
            **Source Branch:** \`${sourceBranch}\`
            **Target Branch:** \`develop\`
            
            ✅ Branch follows naming convention \`feature/*\`
            ✅ Branch was created from \`develop\`
            
            This PR follows GitFlow conventions and can be merged.`;
            } else {
              output = `### GitFlow Feature Branch Validation ❌
            
            **Branch Type:** Feature
            **Source Branch:** \`${sourceBranch}\`
            **Target Branch:** \`develop\`
            
            ❌ **Validation Failed**
            
            This feature branch was not created from \`develop\`. Feature branches must be branched from the \`develop\` branch.
            
            **To fix this:**
            1. Create a new feature branch from develop:
               \`\`\`bash
               git checkout develop
               git pull origin develop
               git checkout -b feature/your-feature-name
               \`\`\`
            2. Cherry-pick your commits or rebase onto the new branch
            3. Open a new PR with the correctly branched feature
            
            **GitFlow Rule:** \`feature/*\` branches must originate from \`develop\``;
            }
            
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: output
            })

      - name: Approve pull request
        uses: andrewmusgrave/automatic-pull-request-review@0.0.2
        with:
          repo-token: '${{ secrets.GITHUB_TOKEN }}'
          event: APPROVE
          body: 'GitFlow validation checks passed, PR Approved 🎊'
        if: job.status == 'success'
